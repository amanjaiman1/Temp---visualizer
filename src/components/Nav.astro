---
interface Props {
  activePath?: string;
}
const { activePath = "" } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/docs", label: "Docs" },
  { href: "/blog", label: "Blog" },
  { href: "/faq", label: "FAQ" },
  { href: "/contact", label: "Contact" },
];

const linkBase =
  "nav-link font-mono text-[0.7rem] tracking-[1.5px] uppercase no-underline px-[14px] py-[6px] rounded-[5px] border border-transparent transition-all duration-[250ms]";
const linkIdle = "text-muted hover:text-cyan hover:border-line hover:bg-[rgba(0,255,200,0.04)]";
const linkActive = "text-cyan border-line bg-[rgba(0,255,200,0.04)]";
---

<nav
  id="navbar"
  class="fixed top-0 inset-x-0 z-[200] flex items-center justify-between px-[40px] py-[14px] bg-[rgba(6,8,16,0.85)] backdrop-blur-[20px] border-b border-line2 transition-all duration-[400ms] [transition-timing-function:cubic-bezier(0.16,1,0.3,1)]"
>
  <a
    href="/"
    class="nav-logo flex items-center gap-[10px] no-underline text-white font-ui font-black text-[1.2rem] tracking-[-1px]"
  >
    <div
      class="nav-logo-icon grid grid-cols-4 items-end gap-[2px] w-[28px] h-[28px] pt-[4px] px-[3px] pb-[3px] border-[1.5px] border-cyan rounded-[5px] animate-logo-pulse"
    >
      <span></span><span></span><span></span><span></span>
    </div>
    <span><em class="text-cyan not-italic">Sort</em>&amp;Visualize</span>
  </a>

  <button
    class="nav-toggle"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="navLinks"
  >
    <span></span><span></span><span></span>
  </button>

  <div class="nav-links flex items-center gap-[6px]" id="navLinks">
    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={[linkBase, activePath === l.href ? linkActive : linkIdle]}
        >
          {l.label}
        </a>
      ))
    }
    <a
      href="/visualiser"
      class="nav-cta font-mono text-[0.72rem] tracking-[1.5px] uppercase font-bold text-black no-underline px-[20px] py-[9px] rounded-[6px] bg-cyan border border-cyan whitespace-nowrap transition-all duration-300 [transition-timing-function:cubic-bezier(0.16,1,0.3,1)] hover:bg-white hover:shadow-[0_0_24px_rgba(0,255,200,0.5)] hover:-translate-y-px"
      >▶ Launch Visualiser</a
    >
  </div>
</nav>

<style>
  /* logo bar heights */
  .nav-logo-icon span {
    background: var(--cyan);
    border-radius: 1px;
    display: block;
  }
  .nav-logo-icon span:nth-child(1) { height: 40%; }
  .nav-logo-icon span:nth-child(2) { height: 70%; }
  .nav-logo-icon span:nth-child(3) { height: 55%; }
  .nav-logo-icon span:nth-child(4) { height: 90%; }

  /* scrolled state (toggled via JS) */
  nav.scrolled {
    padding: 10px 40px;
    background: rgba(6, 8, 16, 0.96);
    border-color: var(--border);
  }

  /* hamburger (hidden until mobile) */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 38px;
    padding: 10px;
    background: rgba(0, 255, 200, 0.05);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: var(--cyan);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease;
  }
  nav.nav-open .nav-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  nav.nav-open .nav-toggle span:nth-child(2) { opacity: 0; }
  nav.nav-open .nav-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 980px) {
    nav { padding: 12px 24px; }
    nav.scrolled { padding: 10px 24px; }
  }

  @media (max-width: 760px) {
    nav { padding: 12px 18px; }
    nav.scrolled { padding: 10px 18px; }
    .nav-toggle { display: flex; }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 6px;
      padding: 0 16px;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      background: rgba(6, 8, 16, 0.98);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid transparent;
      transition: max-height 0.38s cubic-bezier(0.16, 1, 0.3, 1),
        opacity 0.3s ease, padding 0.3s ease, border-color 0.3s ease;
    }
    nav.nav-open .nav-links {
      max-height: 75vh;
      opacity: 1;
      pointer-events: auto;
      padding: 12px 16px 18px;
      border-bottom-color: var(--border);
    }
    .nav-link,
    .nav-cta {
      width: 100%;
      text-align: center;
      padding: 15px 16px;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 460px) {
    .nav-logo { font-size: 1.05rem; }
  }
</style>

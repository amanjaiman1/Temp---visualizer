---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const label =
  "flex items-center gap-[8px] text-[0.6rem] max-[760px]:text-[0.75rem] tracking-[3px] uppercase text-cyan mb-[10px] before:content-[''] before:block before:w-[20px] before:h-[1px] before:bg-cyan";
const h2 = "font-ui font-extrabold text-[1.6rem] max-[760px]:text-[1.4rem] tracking-[-1px] text-white mb-[14px]";
const para = "text-[0.82rem] max-[760px]:text-[0.92rem] text-[#6a7a8a] leading-[1.85] mb-[14px]";
const techItem =
  "flex items-center gap-[10px] text-[0.78rem] max-[760px]:text-[0.88rem] text-ink before:content-['›'] before:text-cyan";

const values = [
  { icon: "🔍", title: "Clarity First", desc: "Every visual choice serves understanding. No clutter, no noise — just signal." },
  { icon: "🆓", title: "Forever Free", desc: "No login, no paywall, no barriers. Learning should be accessible to everyone." },
  { icon: "⚡", title: "Performance Matters", desc: "Smooth animations at 60fps. The tool should feel as fast as the algorithms it teaches." },
  { icon: "🎓", title: "Pedagogical Rigour", desc: "Accurate pseudocode, correct complexity, honest trade-off analysis." },
];

const tech = [
  "Pure vanilla JavaScript — zero dependencies, instant load",
  "Web Audio API for real-time audio feedback",
  "CSS custom properties for consistent theming",
  "requestAnimationFrame-friendly architecture for smooth 60fps animation",
  "Space Mono & Syne typefaces via Google Fonts",
];

const algorithms = [
  "Bubble Sort — the classic teaching algorithm",
  "Selection Sort — minimal write operations",
  "Insertion Sort — excellent for nearly-sorted data",
  "Merge Sort — guaranteed O(n log n), stable",
  "Quick Sort — fastest in practice for random data",
  "Heap Sort — O(1) extra space with O(n log n) guarantee",
  "Shell Sort — generalised insertion with gap sequences",
  "Counting Sort — linear time for bounded integers",
  "Radix Sort — digit-by-digit linear sorting",
  "Tim Sort — the hybrid used in Python, Java, and Swift",
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Sort & Visualize",
  url: "https://sortandvisualize.com/about",
  description: "A free, interactive visualiser for 10 classic sorting algorithms.",
  publisher: { "@type": "Organization", name: "Sort & Visualize", url: "https://sortandvisualize.com/" },
};
---

<BaseLayout
  title="About Sort & Visualize — Our Mission to Make Algorithms Visual"
  description="Sort & Visualize is a free, interactive visualiser for 10 classic sorting algorithms. Learn why we built it, the technology behind it, and the algorithms it covers."
  keywords="about sort and visualize, sorting algorithm tool, learn algorithms, computer science education, algorithm visualiser"
  activePath="/about"
  jsonLd={jsonLd}
>
  <PageHero eyebrow="About Sort &amp; Visualize">
    <Fragment slot="title">Built to make <em class="text-cyan not-italic">CS click</em></Fragment>
    <p class="text-[0.9rem] text-[#5a6a7a] max-w-[480px] mx-auto leading-[1.8]">
      A free, open visualisation tool for sorting algorithms — because seeing is understanding.
    </p>
  </PageHero>

  <div class="max-w-[800px] mx-auto px-[40px] pt-[70px] pb-[100px] max-[980px]:px-[24px] max-[760px]:px-[18px]">
    <!-- Mission -->
    <section class="mb-[56px] animate-fade-up [animation-delay:0.1s]">
      <div class={label}>Mission</div>
      <h2 class={h2}>Why <em class="text-cyan not-italic">Sort &amp; Visualize</em> exists</h2>
      <div class="relative overflow-hidden bg-panel border border-line rounded-[12px] p-[32px] max-[760px]:p-[20px] mb-[20px] before:content-[''] before:absolute before:top-0 before:inset-x-0 before:h-[1px] before:bg-[linear-gradient(90deg,transparent,var(--cyan),transparent)]">
        <p class={para}>
          Sorting algorithms are one of the most fundamental topics in computer science — and one of
          the most commonly misunderstood. Students spend hours reading pseudocode and theory without
          ever truly seeing what's happening inside an algorithm.
        </p>
        <p class={para}>
          Sort &amp; Visualize was built to change that. We believe that
          <strong class="text-ink">visual, interactive learning</strong> creates lasting intuition that
          no textbook can match. Watching Merge Sort split and recombine, or seeing QuickSort pivot
          around an element — these moments make the abstract concrete.
        </p>
        <p class={para + " mb-0"}>
          Our goal is simple: make sorting algorithms approachable, memorable, and even
          <em class="text-cyan not-italic">enjoyable</em> to explore.
        </p>
      </div>
    </section>

    <div class="h-[1px] bg-[linear-gradient(90deg,transparent,var(--border),transparent)] my-[40px]"></div>

    <!-- Values -->
    <section class="mb-[56px] animate-fade-up [animation-delay:0.2s]">
      <div class={label}>Values</div>
      <h2 class={h2}>What we stand <em class="text-cyan not-italic">for</em></h2>
      <div class="grid grid-cols-2 gap-[16px] mt-[24px] max-[760px]:grid-cols-1">
        {
          values.map((v) => (
            <div class="bg-panel border border-line2 rounded-[8px] p-[20px] transition-all duration-300 [transition-timing-function:cubic-bezier(0.16,1,0.3,1)] hover:border-[rgba(0,255,200,0.2)] hover:-translate-y-[2px]">
              <div class="text-[1.4rem] mb-[10px]">{v.icon}</div>
              <div class="font-ui font-bold text-[0.9rem] max-[760px]:text-[1rem] text-white mb-[6px]">{v.title}</div>
              <div class="text-[0.72rem] max-[760px]:text-[0.85rem] text-[#5a6a7a] leading-[1.6]">{v.desc}</div>
            </div>
          ))
        }
      </div>
    </section>

    <div class="h-[1px] bg-[linear-gradient(90deg,transparent,var(--border),transparent)] my-[40px]"></div>

    <!-- Technology -->
    <section class="mb-[56px] animate-fade-up [animation-delay:0.3s]">
      <div class={label}>Technology</div>
      <h2 class={h2}>How it's <em class="text-cyan not-italic">built</em></h2>
      <p class={para}>
        Sort &amp; Visualize is a single-file web application — no frameworks, no dependencies, no build step.
        Just HTML, CSS, and vanilla JavaScript, running entirely in your browser.
      </p>
      <ul class="list-none flex flex-col gap-[8px] mt-[16px]">
        {tech.map((t) => <li class={techItem}>{t}</li>)}
      </ul>
    </section>

    <div class="h-[1px] bg-[linear-gradient(90deg,transparent,var(--border),transparent)] my-[40px]"></div>

    <!-- Algorithms -->
    <section class="mb-[56px] animate-fade-up [animation-delay:0.4s]">
      <div class={label}>Algorithms</div>
      <h2 class={h2}>What's <em class="text-cyan not-italic">covered</em></h2>
      <p class={para}>
        Sort &amp; Visualize visualises 10 foundational sorting algorithms, from introductory to advanced:
      </p>
      <ul class="list-none flex flex-col gap-[8px] mt-[16px]">
        {algorithms.map((a) => <li class={techItem}>{a}</li>)}
      </ul>
    </section>

    <div class="h-[1px] bg-[linear-gradient(90deg,transparent,var(--border),transparent)] my-[40px]"></div>

    <!-- The Team -->
    <section class="mb-[56px] animate-fade-up [animation-delay:0.5s]">
      <div class={label}>Team</div>
      <h2 class={h2}>Who's behind <em class="text-cyan not-italic">Sort &amp; Visualize</em></h2>
      <p class={para}>
        Sort &amp; Visualize is built and maintained by a small team of computer science enthusiasts and educators
        who believe that visual, interactive learning creates deeper understanding than traditional
        textbooks alone. We are software engineers, CS graduates, and self-taught developers who
        remember the frustration of trying to understand algorithm behaviour from static diagrams and
        dry pseudocode.
      </p>
      <p class={para}>
        Our backgrounds span competitive programming, university teaching, full-stack development,
        and open-source contributions. We built Sort &amp; Visualize because we wished it had existed when we
        were learning — and because we believe every student deserves free access to high-quality
        educational tools regardless of their institution or financial situation.
      </p>
      <p class={para}>
        We are committed to keeping Sort &amp; Visualize free, ad-supported (via Google AdSense), and
        continuously improved. If you're an educator using Sort &amp; Visualize in your classroom, a student who
        found it helpful, or a developer who wants to contribute, we'd love to hear from you via our
        <a href="/contact" class="text-cyan hover:underline no-underline">contact page</a>.
      </p>
    </section>

    <div class="h-[1px] bg-[linear-gradient(90deg,transparent,var(--border),transparent)] my-[40px]"></div>

    <!-- Transparency -->
    <section class="mb-[56px] animate-fade-up [animation-delay:0.6s]">
      <div class={label}>Transparency</div>
      <h2 class={h2}>How Sort &amp; Visualize is <em class="text-cyan not-italic">funded</em></h2>
      <p class={para}>
        Sort &amp; Visualize is completely free to use. We cover our hosting and development costs through
        non-intrusive advertising provided by Google AdSense. We will never put educational content
        behind a paywall, require user accounts, or sell user data. Our advertising approach is simple:
        relevant, non-intrusive ads that help keep the lights on without degrading the learning
        experience.
      </p>
      <p class={para}>
        We are selective about the advertising we display and work within Google's strict content
        policies. If you ever see an ad that feels inappropriate for an educational context, please
        let us know via our <a href="/contact" class="text-cyan hover:underline no-underline">contact page</a>
        and we will investigate immediately.
      </p>
    </section>
  </div>
</BaseLayout>

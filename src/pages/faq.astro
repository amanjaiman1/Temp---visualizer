    { "@type": "Question", name: "Why does stability matter in practice?", acceptedAnswer: { "@type": "Answer", text: "Stability matters when sorting by multiple criteria. A stable sort preserves previous ordering within equal groups. Database systems rely on stable sorts for ORDER BY clauses with multiple columns." } },
    { "@type": "Question", name: "Which sorting algorithms are stable?", acceptedAnswer: { "@type": "Answer", text: "The commonly stable algorithms are Merge Sort, Insertion Sort, Bubble Sort, Counting Sort, Radix Sort, and Tim Sort. Quick Sort, Heap Sort, and Selection Sort are unstable." } },
    { "@type": "Question", name: "What is adaptive sorting?", acceptedAnswer: { "@type": "Answer", text: "An adaptive sorting algorithm takes advantage of existing order in the input to sort faster. Insertion Sort runs in O(n) on nearly sorted data. Tim Sort detects sorted runs and exploits them. Heap Sort is non-adaptive, always taking O(n log n)." } },
    { "@type": "Question", name: "What is the difference between iterative and recursive sorting?", acceptedAnswer: { "@type": "Answer", text: "Recursive sorts (Merge Sort, Quick Sort) divide problems using function calls, consuming O(log n) stack space. Iterative sorts (Bubble Sort, Insertion Sort) use loops with O(1) stack space. Most recursive sorts can be rewritten iteratively." } },
    { "@type": "Question", name: "Can Quick Sort be made stable?", acceptedAnswer: { "@type": "Answer", text: "Yes, but it requires O(n) extra space, defeating its main in-place advantage. A stable Quick Sort uses separate arrays for elements less than, equal to, and greater than the pivot. In practice, use Merge Sort or Tim Sort if you need stability." } },
    { "@type": "Question", name: "What are hybrid sorting algorithms?", acceptedAnswer: { "@type": "Answer", text: "Hybrid sorting algorithms combine two or more simpler algorithms to exploit each one's strengths. Tim Sort combines Merge Sort and Insertion Sort. Introsort combines Quick Sort, Heap Sort, and Insertion Sort. These are what production standard libraries actually use." } },
    { "@type": "Question", name: "Which sorting algorithms do I need to know for FAANG interviews?", acceptedAnswer: { "@type": "Answer", text: "Know Merge Sort, Quick Sort, and Heap Sort thoroughly. Also know Insertion Sort for small arrays, Counting/Radix Sort for integer problems, and Tim Sort as the real-world default. Understanding trade-offs matters more than memorising code." } },
    { "@type": "Question", name: "How do I explain Quick Sort in an interview?", acceptedAnswer: { "@type": "Answer", text: "Explain in three steps: choose a pivot, partition the array so smaller elements go left and larger go right, recursively sort both halves. Mention pivot selection strategies, in-place but unstable, O(n log n) average, O(log n) stack space." } },
    { "@type": "Question", name: "What's the follow-up question after implement merge sort?", acceptedAnswer: { "@type": "Answer", text: "Common follow-ups: How would you sort a file that doesn't fit in memory (external merge sort)? Can you do it iteratively (bottom-up)? What is the space complexity? How would you count inversions using merge sort?" } },
    { "@type": "Question", name: "Do I need to memorize all sorting algorithm complexities?", acceptedAnswer: { "@type": "Answer", text: "Yes for interviews. Bubble/Selection/Insertion are O(n squared), Merge/Heap/Quick are O(n log n) average, Counting is O(n+k), Radix is O(nk). More importantly, understand why each has its complexity." } },
    { "@type": "Question", name: "How do I choose between sorting algorithms in a system design interview?", acceptedAnswer: { "@type": "Answer", text: "Consider data size, memory constraints, stability requirements, data distribution, and latency guarantees. Most production systems use language defaults (Tim Sort/Introsort) unless profiling reveals a specific bottleneck." } },
    { "@type": "Question", name: "How do I use the visualiser?", acceptedAnswer: { "@type": "Answer", text: "Open the visualiser page, pick an algorithm from the left panel, then press Sort. Adjust array size and speed with sliders. Use Pause, Step, and Reset to control playback." } },
    { "@type": "Question", name: "What do the bar colours mean?", acceptedAnswer: { "@type": "Answer", text: "Each colour represents an algorithmic state: amber means comparing, red means swapping, cyan is the selected element, purple is the pivot in Quick Sort, and green means confirmed sorted." } },
    { "@type": "Question", name: "What are the keyboard shortcuts?", acceptedAnswer: { "@type": "Answer", text: "Space starts or pauses the sort. R resets the array. Right arrow steps forward one frame when paused. Escape closes the comparison modal." } },
    { "@type": "Question", name: "How do I compare multiple algorithms?", acceptedAnswer: { "@type": "Answer", text: "Click the Compare All button to open a table showing all 10 algorithms side by side with time complexity, space complexity, stability, and sorting method." } },
    { "@type": "Question", name: "Can I turn off the sound?", acceptedAnswer: { "@type": "Answer", text: "Yes, click the speaker button in the controls bar to toggle audio. The sound maps bar values to pitch, so taller bars play higher tones." } },
    { "@type": "Question", name: "Do I need an account to use Sort & Visualize?", acceptedAnswer: { "@type": "Answer", text: "No. Sort & Visualize requires no account, login, or sign-up. Just open the site and start visualising." } },
    { "@type": "Question", name: "Does Sort & Visualize collect any data?", acceptedAnswer: { "@type": "Answer", text: "Sort & Visualize runs entirely in your browser. All sorting happens locally on your device. We collect no personal data and store nothing on any server." } },
    { "@type": "Question", name: "Is Sort & Visualize free?", acceptedAnswer: { "@type": "Answer", text: "Yes, completely and permanently free. There is no paid tier and no premium features. Every algorithm and feature is available to everyone." } },
  ],
};

const catLabel =
  "flex items-center gap-[8px] text-[0.6rem] max-[760px]:text-[0.75rem] tracking-[3px] uppercase text-purple mb-[20px] before:content-[''] before:block before:w-[20px] before:h-[1px] before:bg-purple";
const faqAnswer =
  "overflow-hidden max-h-0 px-[20px] transition-[max-height,padding] duration-[450ms] [transition-timing-function:cubic-bezier(0.16,1,0.3,1)] group-[.open]:max-h-[400px] group-[.open]:pb-[18px] [&_p]:text-[0.78rem] max-[760px]:[&_p]:text-[0.88rem] [&_p]:text-[#6a7a8a] [&_p]:leading-[1.8] [&_a]:text-cyan [&_a]:no-underline [&_a:hover]:underline";
---

<BaseLayout
  title="Sorting Algorithm FAQ — 35+ Questions Answered | Sort & Visualize"
  description="Every sorting algorithm question from Reddit and Quora answered: Quick Sort vs Merge Sort, best algorithm for interviews, Tim Sort explained, stability, Big O, and more. With interactive visualisations."
  keywords="sorting algorithm faq, quicksort vs mergesort reddit, best sorting algorithm, which sorting algorithm to use, tim sort explained, sorting algorithm interview questions, bubble sort useful, stable sort meaning, sorting algorithm comparison, radix sort vs quicksort"
  activePath="/faq"
  jsonLd={jsonLd}
>
  <PageHero eyebrow="Frequently Asked Questions" glow="rgba(176,111,255,0.05)" glowW="700px" glowH="350px">
    <Fragment slot="title">Got <em class="text-cyan not-italic">questions?</em></Fragment>
    <p class="text-[0.9rem] max-[760px]:text-[1rem] text-[#5a6a7a] max-w-[480px] mx-auto leading-[1.8]">
      Everything you need to know about Sort &amp; Visualize and sorting algorithms.
    </p>
  </PageHero>

  <div class="max-w-[760px] mx-auto px-[40px] pt-[70px] pb-[100px] max-[980px]:px-[24px] max-[760px]:px-[18px]">
    {
      categories.map((cat) => (
        <div class="mb-[48px]">
          <div class={catLabel}>{cat.label}</div>
          {cat.items.map((item) => (
            <div class="faq-item group border border-line2 rounded-[8px] mb-[8px] overflow-hidden transition-[border-color] duration-[250ms] hover:border-[rgba(0,255,200,0.15)]">
              <div class="faq-q flex items-center justify-between gap-[16px] cursor-pointer select-none px-[20px] py-[18px] max-[760px]:py-[20px] font-ui font-bold text-[0.9rem] max-[760px]:text-[1rem] text-white transition-[background] duration-[250ms] hover:bg-[rgba(0,255,200,0.03)] group-[.open]:text-cyan">
                <span>{item.q}</span>
                <span class="shrink-0 text-[0.8rem] text-muted transition-[transform,color] duration-[350ms] group-[.open]:rotate-180 group-[.open]:text-cyan">
                  ▼
                </span>
              </div>
              <div class={faqAnswer} set:html={item.a} />
            </div>
          ))}
        </div>
      ))
    }
  </div>

  <script>
    document.querySelectorAll<HTMLElement>(".faq-item").forEach((item) => {
      const q = item.querySelector(".faq-q");
      q?.addEventListener("click", () => {
        const wasOpen = item.classList.contains("open");
        document
          .querySelectorAll(".faq-item")
          .forEach((i) => i.classList.remove("open"));
        if (!wasOpen) item.classList.add("open");
      });
    });
  </script>
</BaseLayout>

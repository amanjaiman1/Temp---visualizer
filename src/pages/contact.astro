---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const field =
  "w-full bg-panel border border-line2 rounded-[6px] px-[14px] py-[11px] text-ink font-mono text-[0.78rem] max-[760px]:text-[0.88rem] outline-none appearance-none transition-[border-color,box-shadow] duration-[250ms] focus:border-cyan focus:shadow-[0_0_0_3px_rgba(0,255,200,0.08)]";
const labelCls = "block text-[0.65rem] max-[760px]:text-[0.75rem] tracking-[1.5px] uppercase text-muted mb-[7px]";

const sidebar = [
  { icon: "🐛", title: "Bug Report", desc: "Found something broken? Tell us which algorithm, what you were doing, and your browser." },
  { icon: "💡", title: "Feature Request", desc: "Want a new algorithm, mode, or feature? We love community-driven ideas." },
  { icon: "🎓", title: "Educational Use", desc: "Using Sort & Visualize in a class or curriculum? We'd love to hear about it and can offer dedicated support." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Sort & Visualize",
  url: "https://sortandvisualize.com/contact",
  description: "Contact the Sort & Visualize team with bug reports, feature requests and feedback.",
  publisher: { "@type": "Organization", name: "Sort & Visualize", url: "https://sortandvisualize.com/" },
};
---

<BaseLayout
  title="Contact Sort & Visualize — Feedback, Bug Reports & Feature Ideas"
  description="Get in touch with the Sort & Visualize team. Send bug reports, feature requests, feedback, or ask about educational use of our free sorting algorithm visualiser."
  keywords="contact sort and visualize, report bug, feature request, algorithm visualiser support, educational use"
  activePath="/contact"
  jsonLd={jsonLd}
>
  <PageHero eyebrow="Get In Touch" glow="rgba(0,255,200,0.05)" glowW="700px" glowH="350px">
    <Fragment slot="title">We'd love to <em class="text-cyan not-italic">hear</em> from you</Fragment>
    <p class="text-[0.9rem] max-[760px]:text-[1rem] text-[#5a6a7a] max-w-[480px] mx-auto leading-[1.8]">
      Bug reports, feature ideas, feedback — all welcome. We read every message.
    </p>
  </PageHero>

  <div class="max-w-[900px] mx-auto px-[40px] pt-[70px] pb-[100px] grid grid-cols-[1fr_1.6fr] gap-[56px] max-[980px]:px-[24px] max-[760px]:px-[18px] max-[760px]:grid-cols-1 max-[760px]:gap-[36px]">
    <!-- Sidebar -->
    <div>
      {
        sidebar.map((s) => (
          <div class="bg-panel border border-line2 rounded-[10px] p-[24px] mb-[16px] transition-all duration-300 [transition-timing-function:cubic-bezier(0.16,1,0.3,1)] hover:border-[rgba(0,255,200,0.15)] hover:-translate-y-[2px]">
            <div class="text-[1.3rem] mb-[10px]">{s.icon}</div>
            <div class="font-ui font-bold text-[0.9rem] max-[760px]:text-[1rem] text-white mb-[6px]">{s.title}</div>
            <div class="text-[0.72rem] max-[760px]:text-[0.85rem] text-[#5a6a7a] leading-[1.6]">{s.desc}</div>
          </div>
        ))
      }
      <div class="bg-panel border border-line2 rounded-[10px] p-[24px] mb-[16px] transition-all duration-300 [transition-timing-function:cubic-bezier(0.16,1,0.3,1)] hover:border-[rgba(0,255,200,0.15)] hover:-translate-y-[2px]">
        <div class="text-[1.3rem] mb-[10px]">📖</div>
        <div class="font-ui font-bold text-[0.9rem] max-[760px]:text-[1rem] text-white mb-[6px]">Check the FAQ</div>
        <div class="text-[0.72rem] max-[760px]:text-[0.85rem] text-[#5a6a7a] leading-[1.6]">Many common questions are already answered.</div>
        <a href="/faq" class="text-[0.7rem] text-cyan no-underline inline-block mt-[8px] hover:underline">View FAQ →</a>
      </div>
    </div>

    <!-- Form -->
    <div>
      <div class="flex items-center gap-[8px] text-[0.6rem] tracking-[3px] uppercase text-cyan mb-[20px] before:content-[''] before:block before:w-[20px] before:h-[1px] before:bg-cyan">
        Send a Message
      </div>

      <div class="grid grid-cols-2 gap-[14px] max-[760px]:grid-cols-1">
        <div class="mb-[18px]">
          <label for="fname" class={labelCls}>First Name</label>
          <input type="text" id="fname" placeholder="Ada" class={field} />
        </div>
        <div class="mb-[18px]">
          <label for="lname" class={labelCls}>Last Name</label>
          <input type="text" id="lname" placeholder="Lovelace" class={field} />
        </div>
      </div>

      <div class="mb-[18px]">
        <label for="email" class={labelCls}>Email Address</label>
        <input type="email" id="email" placeholder="ada@example.com" class={field} />
      </div>

      <div class="mb-[18px]">
        <label for="subject" class={labelCls}>Subject</label>
        <select id="subject" class={field + " [&>option]:bg-bg2"}>
          <option value="">Select a topic...</option>
          <option value="bug">Bug Report</option>
          <option value="feature">Feature Request</option>
          <option value="education">Educational Use</option>
          <option value="feedback">General Feedback</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="mb-[18px]">
        <label for="message" class={labelCls}>Message</label>
        <textarea id="message" placeholder="Tell us what's on your mind..." class={field + " resize-y min-h-[130px]"}></textarea>
      </div>

      <button
        id="submitBtn"
        class="inline-flex items-center justify-center gap-[8px] w-full mt-[4px] font-mono text-[0.78rem] max-[760px]:text-[0.88rem] font-bold tracking-[1px] text-black bg-cyan border border-cyan px-[28px] py-[13px] rounded-[6px] cursor-pointer transition-all duration-300 [transition-timing-function:cubic-bezier(0.16,1,0.3,1)] hover:bg-white hover:shadow-[0_0_24px_rgba(0,255,200,0.4)] hover:-translate-y-px active:translate-y-0"
      >
        <span>⟶</span> Send Message
      </button>

      <div
        id="successMsg"
        class="hidden bg-[rgba(57,255,133,0.06)] border border-[rgba(57,255,133,0.2)] rounded-[8px] p-[18px_20px] text-[0.78rem] text-green text-center mt-[16px] animate-fade-up"
      >
        ✓ Message sent! We'll get back to you soon.
      </div>
    </div>
  </div>

  <script>
    const btn = document.getElementById("submitBtn");
    btn?.addEventListener("click", () => {
      const email = (document.getElementById("email") as HTMLInputElement)?.value;
      const message = (document.getElementById("message") as HTMLTextAreaElement)?.value;
      if (!email || !message) {
        alert("Please fill in at least your email and message.");
        return;
      }
      document.getElementById("successMsg")?.classList.remove("hidden");
      document
        .querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>("input, textarea, select")
        .forEach((el) => (el.value = ""));
    });
  </script>
</BaseLayout>
